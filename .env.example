# Copy to .env and fill in. Only the keys for the models you use are needed.

# OpenRouter — for hosted models, e.g. the Mind2Web judge (Claude, Gemini, GPT-4o...)
OPENROUTER_API_KEY=

# Alibaba DashScope — only if you select a native Qwen (non-vLLM) model
DASHSCOPE_API_KEY=

# Override any vLLM endpoint: VLLM_<MODELKEY>_URL (key upper-cased, - / . -> _)
# Defaults live in mm_agents/model_endpoints.py.
# VLLM_QWEN35_VL_URL=http://localhost:8010/v1
# VLLM_QWEN35_27B_URL=http://localhost:8012/v1
